---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import team from '../data/team.json';
import siteSettings from '../data/site-settings.json';

const homeEntry = await getCollection('pages', ({ slug }) => slug === 'home');
const home = homeEntry[0];
const caseStudies = await getCollection('case-studies');
const sortedCaseStudies = caseStudies.sort((a, b) => a.data.order - b.data.order);
const featuredCaseStudies = sortedCaseStudies.filter((entry) =>
	home.data.featuredCaseStudies.featuredSlugs.includes(entry.slug),
);
---

<Layout title={home.data.title} description={home.data.description}>
	<main>
		<section class="hero section">
			<div class="container hero-grid">
				<div class="hero-copy">
					<p class="eyebrow">{home.data.hero.eyebrow}</p>
					<h1>{home.data.hero.title}</h1>
					<p class="hero-lede">{home.data.hero.subtitle}</p>
					<div class="hero-actions">
						<a class="button button-primary" href={home.data.hero.primaryCtaHref}>{home.data.hero.primaryCtaLabel}</a>
						<a class="button button-secondary" href={home.data.hero.secondaryCtaHref}>{home.data.hero.secondaryCtaLabel}</a>
					</div>
				</div>
				<div class="hero-panel card">
					<div class="hero-panel-head">
						<span class="status-dot"></span>
						<span>Structured content system</span>
					</div>
					<div class="hero-panel-body">
						{home.data.hero.stats.map((stat) => (
							<div class="stat-block">
								<strong>{stat.value}</strong>
								<span>{stat.label}</span>
							</div>
						))}
					</div>
					<div class="hero-panel-foot">
						<p>Astro front-end + Spertu-managed structured content + Git-based deployment</p>
					</div>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="container">
				<div class="section-heading">
					<p class="eyebrow">{home.data.services.eyebrow}</p>
					<h2>{home.data.services.title}</h2>
					<p>{home.data.services.description}</p>
				</div>
				<div class="grid services-grid">
					{home.data.services.items.map((item) => (
						<article class="card service-card">
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="section" id="case-studies">
			<div class="container">
				<div class="section-heading">
					<p class="eyebrow">{home.data.featuredCaseStudies.eyebrow}</p>
					<h2>{home.data.featuredCaseStudies.title}</h2>
					<p>{home.data.featuredCaseStudies.description}</p>
				</div>
				<div class="grid case-studies-grid">
					{featuredCaseStudies.map((study) => (
						<a class="card case-study-card" href={`/case-studies/${study.slug}/`}>
							<div class="case-study-accent" style={`background: ${study.data.accent};`}></div>
							<div class="case-study-content">
								<p class="case-study-meta">{study.data.client} · {study.data.sector}</p>
								<h3>{study.data.title}</h3>
								<p>{study.data.description}</p>
								<ul>
									{study.data.results.slice(0, 2).map((result) => <li>{result}</li>)}
								</ul>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		<section class="section">
			<div class="container team-shell card">
				<div class="section-heading">
					<p class="eyebrow">{home.data.team.eyebrow}</p>
					<h2>{home.data.team.title}</h2>
					<p>{home.data.team.description}</p>
				</div>
				<div class="grid team-grid">
					{team.map((member) => (
						<article class="team-card">
							<div class="avatar">{member.name.split(' ').map((part) => part[0]).join('')}</div>
							<h3>{member.name}</h3>
							<p class="team-role">{member.role}</p>
							<p>{member.bio}</p>
							<a href={`mailto:${member.email}`}>{member.email}</a>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="section" id="contact">
			<div class="container">
				<div class="contact-card card">
					<div>
						<p class="eyebrow">{home.data.contact.eyebrow}</p>
						<h2>{home.data.contact.title}</h2>
						<p>{home.data.contact.description}</p>
					</div>
					<div class="contact-actions">
						<a class="button button-primary" href={siteSettings.ctaHref}>{siteSettings.ctaLabel}</a>
						<div class="contact-meta">
							<span>{siteSettings.primaryEmail}</span>
							<span>{siteSettings.primaryPhone}</span>
							<span>{siteSettings.location}</span>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.hero {
		padding: 2rem 0 4rem;
	}

	.hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
		gap: 1.5rem;
		align-items: stretch;
	}

	.hero-copy h1,
	.contact-card h2 {
		margin: 1rem 0;
		font-size: clamp(3rem, 6vw, 5.5rem);
		line-height: 0.94;
		max-width: 12ch;
	}

	.hero-lede,
	.contact-card p,
	.service-card p,
	.case-study-card p,
	.team-card p {
		color: var(--text-muted);
		line-height: 1.75;
	}

	.hero-actions,
	.contact-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.95rem 1.25rem;
		border-radius: 999px;
		border: 1px solid var(--line);
		font-weight: 600;
	}

	.button-primary {
		background: linear-gradient(135deg, var(--accent) 0%, var(--accent-strong) 100%);
		color: white;
		border-color: transparent;
	}

	.button-secondary {
		background: rgba(11, 16, 32, 0.5);
	}

	.hero-panel {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}

	.hero-panel-head,
	.hero-panel-foot,
	.case-study-meta,
	.team-role,
	.contact-meta {
		color: var(--text-muted);
	}

	.hero-panel-head {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.status-dot {
		width: 0.7rem;
		height: 0.7rem;
		border-radius: 50%;
		background: var(--success);
		box-shadow: 0 0 0 6px rgba(134, 239, 172, 0.12);
	}

	.hero-panel-body {
		display: grid;
		gap: 1rem;
		margin: 1.5rem 0;
	}

	.stat-block {
		padding: 1rem;
		border: 1px solid var(--line);
		border-radius: var(--radius-sm);
		background: rgba(148, 163, 184, 0.05);
	}

	.stat-block strong {
		display: block;
		font-size: 2rem;
		margin-bottom: 0.35rem;
	}

	.services-grid,
	.team-grid {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.service-card,
	.team-card {
		padding: 1.5rem;
	}

	.service-card h3,
	.case-study-card h3,
	.team-card h3 {
		margin: 0 0 0.65rem;
		font-size: 1.35rem;
	}

	.case-studies-grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.case-study-card {
		overflow: hidden;
	}

	.case-study-accent {
		height: 12rem;
	}

	.case-study-content {
		padding: 1.5rem;
	}

	.case-study-content ul {
		padding-left: 1.1rem;
		margin: 1rem 0 0;
	}

	.team-shell {
		padding: 2rem;
	}

	.avatar {
		width: 3rem;
		height: 3rem;
		margin-bottom: 1rem;
		display: grid;
		place-items: center;
		border-radius: 50%;
		background: var(--accent-soft);
		color: var(--text);
		font-weight: 700;
	}

	.contact-card {
		padding: 2rem;
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
		gap: 1.5rem;
		align-items: center;
	}

	.contact-meta {
		display: grid;
		gap: 0.45rem;
	}

	@media (max-width: 980px) {
		.hero-grid,
		.contact-card,
		.services-grid,
		.team-grid,
		.case-studies-grid {
			grid-template-columns: 1fr;
		}

		.hero-copy h1,
		.contact-card h2 {
			max-width: none;
		}
	}
</style>
